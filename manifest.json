{
  "key": "",
  "name": "QA",
  "version": "1.0",
  "manifest_version": 3,

  "permissions": [
    "identity",
    "storage",
    "sidePanel"
  ],

  "host_permissions": [
    "https://login.microsoftonline.com/*",
    "https://graph.microsoft.com/*",
    "https://audit-ops.traxtech.com/"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "Open Panel"
  },

  "side_panel": {
    "default_path": "index.html"
  }
}